# Playwright E2E environment configuration.
# Copy to `.env` (never commit real values) or create per-env files:
#   .env.dev / .env.qa / .env.staging / .env.uat / .env.prod
# Select the environment with TEST_ENV (defaults to dev).

# Target application URL. dev defaults to http://localhost:4200,
# prod defaults to https://rabinr.in — override here as needed.
# BASE_URL=https://qa.example.com

# CI toggles (set automatically by GitHub Actions)
# CI=true

{
  "name": "portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps",
    "e2e:smoke": "playwright test --grep @smoke",
    "e2e:regression": "playwright test --grep @regression",
    "e2e:visual": "playwright test --grep @visual --project=chromium",
    "e2e:visual:update": "playwright test --grep @visual --project=chromium --update-snapshots",
    "e2e:a11y": "playwright test --grep @a11y",
    "e2e:perf": "playwright test --grep @perf --project=chromium",
    "e2e:chromium": "playwright test --project=chromium",
    "e2e:headed": "playwright test --headed --project=chromium",
    "e2e:debug": "playwright test --debug --project=chromium",
    "e2e:report": "playwright show-report",
    "e2e:trace": "playwright show-trace",
    "e2e:allure": "cross-env ALLURE=1 playwright test",
    "e2e:lint": "eslint e2e playwright.config.ts"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/aria": "^21.2.11",
    "@angular/cdk": "^21.2.11",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.11",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@emailjs/browser": "^4.4.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "gsap": "^3.15.0",
    "marked": "^18.0.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "allure-playwright": "^3.10.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-plugin-playwright": "^2.10.4",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.0.8"
  }
}

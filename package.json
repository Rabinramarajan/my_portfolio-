{
  "name": "my-portfolio-ng22",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "images": "node scripts/generate-images.mjs",
    "brand": "node scripts/generate-brand-assets.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "start": "ng serve",
    "build": "ng build",
    "build:stats": "ng build --stats-json",
    "analyze": "ng build --stats-json && npx --yes esbuild-visualizer --metadata dist/my-portfolio-ng22/stats.json --open",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,html}": [
      "prettier --write"
    ],
    "*.{scss,json,md}": [
      "prettier --write"
    ]
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/animations": "^22.0.7",
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/material": "^22.0.5",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-server": "22.0.7",
    "@angular/router": "^22.0.7",
    "@angular/service-worker": "^22.0.7",
    "@angular/ssr": "^22.0.7",
    "@emailjs/browser": "^4.4.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "gsap": "^3.15.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
